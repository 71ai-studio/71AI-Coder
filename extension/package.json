{
  "name": "vcoder",
  "displayName": "VDS-Coder Agent",
  "description": "VDS-Coder Agent for VS Code",
  "version": "0.1.4",
  "private": true,
  "publisher": "vcoder",
  "license": "MIT",
  "engines": {
    "vscode": "^1.94.0",
    "node": ">=22"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "server",
    "images"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vcoder.connect",
        "title": "vcoder: Connect to Server"
      },
      {
        "command": "vcoder.openTerminal",
        "title": "VDS-Coder Agent: Open",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "vcoder.openNewTerminal",
        "title": "VDS-Coder Agent: Open in New Tab",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "vcoder.addFilepathToTerminal",
        "title": "Add Filepath to Terminal"
      },
      {
        "command": "vcoder.openTUI",
        "title": "VDS-Coder Agent: Open Terminal (TUI)"
      },
      {
        "command": "vcoder.restartServer",
        "title": "vcoder: Restart Server"
      }
    ],
    "configuration": {
      "title": "vcoder",
      "properties": {
        "vcoder.port": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "Preferred port for the vcoder server. 0 = auto (try 4096, fall back to a free port). Restart the server (vcoder: Restart Server) after changing."
        },
        "vcoder.noProxy": {
          "type": "string",
          "default": "localhost,127.0.0.1,::1",
          "description": "Comma-separated list of hosts that bypass any HTTP_PROXY/HTTPS_PROXY when the spawned vcoder server makes outbound calls. Used as the NO_PROXY env var. Restart the server after changing."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "vcoder.openNewTerminal",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vcoder.openTerminal",
        "title": "Run vcoder",
        "key": "ctrl+escape",
        "mac": "cmd+escape",
        "win": "ctrl+escape",
        "linux": "ctrl+escape"
      },
      {
        "command": "vcoder.openNewTerminal",
        "title": "Run vcoder",
        "key": "ctrl+shift+escape",
        "mac": "cmd+shift+escape",
        "win": "ctrl+shift+escape",
        "linux": "ctrl+shift+escape"
      },
      {
        "command": "vcoder.addFilepathToTerminal",
        "title": "vcoder: Insert At-Mentioned",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "win": "ctrl+alt+K",
        "linux": "ctrl+alt+K"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:server": "node build-server.js",
    "compile": "npm run check-types && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run build:server && node esbuild.js --production",
    "vsix": "npm run package && npm version patch --no-git-tag-version && vsce package --no-dependencies",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@tsconfig/node22": "22.0.2",
    "@types/node": "22.13.9",
    "@types/vscode": "^1.94.0",
    "@vscode/vsce": "3.7.0",
    "esbuild": "^0.25.3",
    "typescript": "5.8.2"
  }
}
